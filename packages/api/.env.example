# Database
DATABASE_URL=postgresql://basis:basis@localhost:5432/basis_platform

# Redis
REDIS_URL=redis://localhost:6379

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=basis
KEYCLOAK_CLIENT_ID=basis-api
KEYCLOAK_CLIENT_SECRET=

# OpenAI (leave BASE_URL empty for default api.openai.com)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Coolify
COOLIFY_URL=
COOLIFY_API_TOKEN=

# App
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:3002

# CRM Credentials Encryption (AES-256-GCM, 32-byte hex)
CRM_ENCRYPTION_KEY=
